@model PaymentGatewayViewModel
@{
    ViewData["Title"] = "Razorpay Payment";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            @if (string.IsNullOrEmpty(Model?.RazorpayKeyId) || string.IsNullOrEmpty(Model?.RazorpayOrderId))
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>
                    <strong>Payment Gateway Error</strong>
                    <p class="mb-0 mt-2">Unable to initialize payment gateway. Please try again.</p>
                    <div class="mt-3">
                        <a href="/Order/Details/@Model?.OrderId" class="btn btn-sm btn-outline-danger">
                            <i class="bi bi-arrow-left me-2"></i>Back to Order
                        </a>
                    </div>
                </div>
            }

            <div class="card border-0 shadow-lg">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0 fw-bold"><i class="bi bi-credit-card me-2"></i>Complete Your Payment</h5>
                </div>
                <div class="card-body">
                    <div class="alert alert-info" role="alert">
                        <i class="bi bi-info-circle me-2"></i>
                        Click the button below to proceed to secure payment gateway
                    </div>

                    <div class="mb-4">
                        <p class="text-muted mb-1"><small>Order Number</small></p>
                        <h6 class="fw-bold">@Model?.OrderNumber</h6>
                    </div>

                    <div class="mb-4">
                        <p class="text-muted mb-1"><small>Amount to Pay</small></p>
                        <h3 class="fw-bold text-success">₹@(Model?.Amount / 100m ?? 0).00</h3>
                    </div>

                    <hr>

                    <form id="paymentForm" method="POST" asp-action="VerifyPayment">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="orderId" value="@Model?.OrderId" />
                        <input type="hidden" id="razorpay_payment_id" name="razorpayPaymentId" />
                        <input type="hidden" id="razorpay_order_id" name="razorpayOrderId" value="@Model?.RazorpayOrderId" />
                        <input type="hidden" id="razorpay_signature" name="razorpaySignature" />

                        <button type="button" id="rzp-button1" class="btn btn-primary btn-lg w-100 fw-semibold" onclick="openRazorpayCheckout(event)" @(string.IsNullOrEmpty(Model?.RazorpayKeyId) || string.IsNullOrEmpty(Model?.RazorpayOrderId) ? "disabled" : "")>
                            <i class="bi bi-lock me-2"></i>Pay Now with Razorpay
                        </button>
                    </form>

                    <div class="mt-3">
                        <a href="/Order/Details/@Model?.OrderId" class="btn btn-outline-secondary w-100">
                            <i class="bi bi-arrow-left me-2"></i>Cancel Payment
                        </a>
                    </div>

                    <div class="mt-3 text-center">
                        <p class="text-muted small mb-0">
                            <i class="bi bi-shield-check me-1"></i>
                            Secure payments powered by Razorpay
                        </p>
                    </div>
                </div>
            </div>

            <div class="card border-0 shadow-sm mt-3">
                <div class="card-body">
                    <h6 class="fw-bold mb-3">Payment Methods Available</h6>
                    <ul class="list-unstyled small text-muted">
                        <li><i class="bi bi-check-circle-fill text-success me-2"></i>UPI (PhonePe, Google Pay, BHIM)</li>
                        <li><i class="bi bi-check-circle-fill text-success me-2"></i>Credit/Debit Cards</li>
                        <li><i class="bi bi-check-circle-fill text-success me-2"></i>Net Banking</li>
                        <li><i class="bi bi-check-circle-fill text-success me-2"></i>Digital Wallets</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://checkout.razorpay.com/v1/checkout.js"></script>
    <script>
        function openRazorpayCheckout(e) {
            e.preventDefault();

            var keyId = "@Model?.RazorpayKeyId";
            var razorpayOrderId = "@Model?.RazorpayOrderId";
            var amount = @(Model?.Amount ?? 0);
            var orderNumber = "@Model?.OrderNumber";
            var userEmail = "@Model?.UserEmail";
            var userPhone = "@Model?.UserPhone";

            console.log("=== Razorpay Checkout Debug Info ===");
            console.log("Key ID: " + keyId);
            console.log("Order ID: " + razorpayOrderId);
            console.log("Amount: " + amount);
            console.log("Order Number: " + orderNumber);
            console.log("User Email: " + userEmail);
            console.log("User Phone: " + userPhone);
            console.log("=====================================");

            // Validation checks
            if (!keyId || keyId.trim() === "") {
                alert("❌ Error: Razorpay API Key is missing.\n\nPlease ensure your appsettings.json has the correct Razorpay credentials.");
                console.error("Razorpay Key ID is empty!");
                return false;
            }

            if (!razorpayOrderId || razorpayOrderId.trim() === "") {
                alert("❌ Error: Order ID is missing.\n\nPlease try placing the order again.");
                console.error("Razorpay Order ID is empty!");
                return false;
            }

            if (amount <= 0) {
                alert("❌ Error: Invalid amount.\n\nPlease check your cart and try again.");
                console.error("Amount is invalid: " + amount);
                return false;
            }

            var options = {
                "key": keyId,
                "amount": amount,
                "currency": "INR",
                "name": "Grocery Store",
                "description": "Order #" + orderNumber,
                "order_id": razorpayOrderId,
                "handler": function (response) {
                    console.log("✅ Payment successful");
                    console.log("Payment ID: " + response.razorpay_payment_id);
                    console.log("Order ID: " + response.razorpay_order_id);
                    console.log("Signature: " + response.razorpay_signature);
                    
                    document.getElementById('razorpay_payment_id').value = response.razorpay_payment_id;
                    document.getElementById('razorpay_signature').value = response.razorpay_signature;
                    document.getElementById('paymentForm').submit();
                },
                "prefill": {
                    "email": userEmail,
                    "contact": userPhone
                },
                "theme": {
                    "color": "#28a745"
                },
                "modal": {
                    "ondismiss": function() {
                        console.log("❌ Payment modal closed without completion");
                        window.location.href = '/Order/PaymentFailure/@Model?.OrderId';
                    }
                }
            };

            try {
                console.log("Opening Razorpay checkout...");
                var rzp1 = new Razorpay(options);
                rzp1.open();
            } catch (error) {
                console.error("❌ Error opening Razorpay: " + error.message);
                alert("❌ Error: Could not open payment gateway.\n\nError: " + error.message + "\n\nPlease check your internet connection and try again.");
            }
        }

        // Auto-run on page load
        document.addEventListener('DOMContentLoaded', function() {
            console.log("✅ Payment Gateway page loaded successfully");
        });
    </script>
}

