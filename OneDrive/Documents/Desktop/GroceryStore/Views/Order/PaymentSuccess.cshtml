@model Order
@{
    ViewData["Title"] = "Payment Successful";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card border-0 shadow-lg text-center">
                <div class="card-body p-5">
                    <div class="mb-4">
                        <div class="display-1 text-success">
                            <i class="bi bi-check-circle-fill"></i>
                        </div>
                    </div>

                    <h2 class="fw-bold mb-2">Payment Successful!</h2>
                    <p class="text-muted mb-4">Your payment has been processed successfully.</p>

                    <div class="alert alert-light border-start border-4 border-success mb-4">
                        <div class="row">
                            <div class="col-6 text-start">
                                <p class="mb-2"><small class="text-muted">Order Number</small></p>
                                <h6 class="fw-bold">@Model.OrderNumber</h6>
                            </div>
                            <div class="col-6 text-start">
                                <p class="mb-2"><small class="text-muted">Order Status</small></p>
                                <h6 class="fw-bold"><span class="badge bg-success">@Model.Status</span></h6>
                            </div>
                        </div>
                        <hr class="my-2">
                        <div class="row">
                            <div class="col-6 text-start">
                                <p class="mb-0"><small class="text-muted">Payment Method</small></p>
                                <small class="fw-semibold">@(Model.Payment?.Method ?? "N/A")</small>
                            </div>
                            <div class="col-6 text-start">
                                <p class="mb-0"><small class="text-muted">Amount Paid</small></p>
                                <small class="fw-semibold">₹@(Model.TotalAmountCents / 100m).00</small>
                            </div>
                        </div>
                    </div>

                    <div class="mb-4">
                        <p class="text-muted small mb-3">
                            <i class="bi bi-info-circle me-2"></i>
                            Your order will be processed and delivered soon. Track your order status below.
                        </p>
                    </div>

                    <div class="d-grid gap-2">
                        <a href="/Order/Details/@Model.Id" class="btn btn-primary btn-lg fw-semibold">
                            <i class="bi bi-box-seam me-2"></i>View Order Details
                        </a>
                        <a href="/" class="btn btn-outline-secondary fw-semibold">
                            <i class="bi bi-house me-2"></i>Continue Shopping
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
