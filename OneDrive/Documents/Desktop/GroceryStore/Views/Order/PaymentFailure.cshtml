@model Order
@{
    ViewData["Title"] = "Payment Failed";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card border-0 shadow-lg text-center">
                <div class="card-body p-5">
                    <div class="mb-4">
                        <div class="display-1 text-danger">
                            <i class="bi bi-x-circle-fill"></i>
                        </div>
                    </div>

                    <h2 class="fw-bold mb-2">Payment Failed</h2>
                    <p class="text-muted mb-4">Unfortunately, your payment could not be processed.</p>

                    <div class="alert alert-light border-start border-4 border-danger mb-4">
                        <div class="row">
                            <div class="col-6 text-start">
                                <p class="mb-2"><small class="text-muted">Order Number</small></p>
                                <h6 class="fw-bold">@Model.OrderNumber</h6>
                            </div>
                            <div class="col-6 text-start">
                                <p class="mb-2"><small class="text-muted">Payment Status</small></p>
                                <h6 class="fw-bold"><span class="badge bg-danger">@Model.Payment?.Status</span></h6>
                            </div>
                        </div>
                        <hr class="my-2">
                        <div class="text-start">
                            <p class="mb-0"><small class="text-muted">Amount</small></p>
                            <small class="fw-semibold">₹@(Model.TotalAmountCents / 100m).00</small>
                        </div>
                    </div>

                    <div class="mb-4">
                        <div class="alert alert-warning" role="alert">
                            <i class="bi bi-exclamation-triangle me-2"></i>
                            <strong>What to do next:</strong>
                            <ul class="mb-0 mt-2">
                                <li>Check your payment method and try again</li>
                                <li>Ensure sufficient balance in your account</li>
                                <li>Try a different payment method</li>
                                <li>Contact your bank if the issue persists</li>
                            </ul>
                        </div>
                    </div>

                    <div class="d-grid gap-2">
                        <a href="/Order/PaymentGateway/@Model.Id" class="btn btn-primary btn-lg fw-semibold">
                            <i class="bi bi-arrow-counterclockwise me-2"></i>Retry Payment
                        </a>
                        <a href="/Order/Details/@Model.Id" class="btn btn-outline-secondary fw-semibold">
                            <i class="bi bi-box-seam me-2"></i>View Order
                        </a>
                        <a href="/" class="btn btn-outline-secondary fw-semibold">
                            <i class="bi bi-house me-2"></i>Back to Home
                        </a>
                    </div>

                    <p class="text-muted small mt-4 mb-0">
                        <i class="bi bi-headset me-2"></i>
                        Need help? <a href="/" class="text-primary">Contact Support</a>
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>
